# Public PK-DB instance.
PKDB_API_BASE_URL=https://pk-db.com/api/v1
PKDB_OPENAPI_URL=https://pk-db.com/api/v1/swagger.json

# Optional token for authenticated/write endpoints.
# PKDB_API_TOKEN=...

# Set to false if startup must fail when the live Swagger document is unavailable.
PKDB_USE_FALLBACK_SPEC=true

# stdio is the default for local MCP clients.
PKDB_MCP_TRANSPORT=stdio
PKDB_MCP_SERVER_NAME=pkdb-mcp
PKDB_HTTP_TIMEOUT_SECONDS=30

# Optional HTTP/SOCKS proxy URL (e.g., http://proxy:8080, socks5://proxy:1080).
# SOCKS support requires the optional "socks" extra: uv sync --extra socks
# PKDB_PROXY=http://proxy:8080
